#!/bin/sh
set -eu

ENV_FILE="/etc/default/samba-ad-backup"
BACKUP_ROOT="/var/backups/samba-ad"

mkdir -p "$BACKUP_ROOT"
WORKDIR=$(mktemp -d "$BACKUP_ROOT/tmp.XXXXXX")

cleanup() {
    rm -rf "$WORKDIR"
}

trap cleanup EXIT INT TERM

run_backup() {
    # Offline mode is designed for constrained-memory DCs and performs a
    # service-coordinated backup from disk rather than a full online clone.
    /usr/bin/samba-tool domain backup offline \
        --targetdir="$WORKDIR"
}

BACKUP_ERR="$WORKDIR/backup.err"

if ! run_backup 2>"$BACKUP_ERR"; then
    cat "$BACKUP_ERR" >&2
    exit 1
fi

backup_file=$(find "$WORKDIR" -maxdepth 2 -type f \( -name '*.tar.bz2' -o -name '*.tar.gz' -o -name '*.tgz' \) | head -n 1)

if [ -z "$backup_file" ]; then
    echo "samba-tool did not produce a backup archive" >&2
    exit 1
fi

object_key="samba-ad/$(hostname -s)/$(basename "$backup_file")"
local_backup_file="$BACKUP_ROOT/$(basename "$backup_file")"

mv "$backup_file" "$local_backup_file"

echo "Local backup file: $local_backup_file"

echo "Backup object key: $object_key"

if [ -r "$ENV_FILE" ]; then
    set -a
    . "$ENV_FILE"
    set +a

    : "${AWS_ACCESS_KEY_ID:?missing AWS_ACCESS_KEY_ID}"
    : "${AWS_SECRET_ACCESS_KEY:?missing AWS_SECRET_ACCESS_KEY}"
    : "${S3_BUCKET:?missing S3_BUCKET}"
    : "${S3_ENDPOINT:?missing S3_ENDPOINT}"

    export AWS_ACCESS_KEY_ID
    export AWS_SECRET_ACCESS_KEY
    export AWS_EC2_METADATA_DISABLED=true
    export AWS_DEFAULT_REGION="${AWS_DEFAULT_REGION:-us-east-1}"

    /usr/bin/aws --endpoint-url "$S3_ENDPOINT" s3 cp "$local_backup_file" "s3://$S3_BUCKET/$object_key" --only-show-errors
    echo "Uploaded backup to s3://$S3_BUCKET/$object_key"
else
    echo "S3 env file not present at $ENV_FILE, keeping local backup only"
fi
